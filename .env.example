APP_NAME=Medibeheer
APP_ENV=local
APP_KEY=
APP_PREVIOUS_KEYS=
EMAIL_HASH_KEY=
EMAIL_HASH_PREVIOUS_KEYS=
APP_DEBUG=true
APP_URL=https://medibeheer.test

# Optional: override the default meta description for search engines and social previews.
# SEO_DESCRIPTION=
# SEO_LOCALE=nl_BE

APP_LOCALE=nl
APP_FALLBACK_LOCALE=nl
APP_FAKER_LOCALE=nl_NL

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=
# DB_PORT=3306
# DB_DATABASE=
# DB_USERNAME=
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=30
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=pusher

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=eu

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@example.com
VITE_VAPID_PUBLIC_KEY="${VAPID_PUBLIC_KEY}"
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=postmark
POSTMARK_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=10
MAIL_FROM_ADDRESS="noreply@medibeheer.be"
MAIL_FROM_NAME="Medibeheer"

FAMILY_INVITATION_EXPIRY_DAYS=14
FAMILY_INVITATION_DAILY_MAX=20
FAMILY_INVITATION_RECIPIENT_DAILY_MAX=10
DOCTOR_INVITATION_EXPIRY_DAYS=14
DOCTOR_INVITATION_DAILY_MAX=20
DOCTOR_INVITATION_RECIPIENT_DAILY_MAX=10
MEDICATION_PLAN_PROPOSAL_EXPIRY_DAYS=14

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Places API (New) — browser key restricted by HTTP referrer + API (Places API New).
# VITE_GOOGLE_MAPS_API_KEY=

PRIVACY_POLICY_VERSION=2026-06-06
# Optional dedicated privacy contact; defaults to MAIL_FROM_ADDRESS when empty.
# PRIVACY_CONTACT_EMAIL=privacy@example.com
PRIVACY_SECURITY_ACTIVITY_LOG_RETENTION_DAYS=90
PRIVACY_DATA_ACTIVITY_LOG_RETENTION_DAYS=365
PRIVACY_SESSION_RETENTION_DAYS=30

# When APP_URL is https://, the Vite dev server uses TLS (Laravel Herd / Valet certificates).
# If the site host differs from the project folder name, set the HMR host explicitly, for example:
# VITE_DEV_SERVER_HOST=medibeheer.test

# iPhone op hetzelfde WiFi (HTTPS via Expose; start met: ./scripts/iphone-dev.sh)
# Zet APP_URL en VAPID_SUBJECT op de Public URL die herd share toont, en SESSION_SECURE_COOKIE=true.
# Daarna: php artisan config:clear && npm run build
